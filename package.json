{
  "name": "geoportal-sqlite-downloader",
  "version": "1.0.0",
  "description": "Download geoportal.lt open data and store it in SQLite with an interactive search UI",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "fetch-metadata": "bun run src/scripts/fetch-metadata.ts",
    "sync": "bun run src/scripts/sync.ts"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "puppeteer": "^22.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/cli-progress": "^3.11.6"
  },
  "trustedDependencies": [
    "gdal-async"
  ]
}
